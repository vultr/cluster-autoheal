{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "controller": {
      "type": "object",
      "properties": {
        "cloudProvider": {
          "type": "string",
          "enum": ["vultr"]
        },
        "actionOverrideLabel": {
          "type": "string",
          "minLength": 1
        },
        "leaderElect": {
          "type": "boolean"
        },
        "leaderElectionNamespace": {
          "type": "string",
          "minLength": 1
        },
        "leaderElectionName": {
          "type": "string",
          "minLength": 1
        },
        "scanInterval": {
          "type": "string",
          "pattern": "^[0-9]+(ns|us|ms|s|m|h)$"
        },
        "drainTimeout": {
          "type": "string",
          "pattern": "^[0-9]+(ns|us|ms|s|m|h)$"
        },
        "rebootReadyTimeout": {
          "type": "string",
          "pattern": "^[0-9]+(ns|us|ms|s|m|h)$"
        },
        "healthAddr": {
          "type": "string"
        },
        "cordonBeforeRepair": {
          "type": "boolean"
        },
        "drainBeforeRepair": {
          "type": "boolean"
        },
        "uncordonAfterReboot": {
          "type": "boolean"
        },
        "deleteEmptyDirData": {
          "type": "boolean"
        },
        "dryRun": {
          "type": "boolean"
        },
        "logVerbosity": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        },
        "tag": {
          "type": "string"
        }
      }
    },
    "dnsPolicy": {
      "type": "string",
      "enum": ["ClusterFirst", "Default", "None"]
    },
    "vultr": {
      "type": "object",
      "properties": {
        "apiKey": {
          "type": "string"
        },
        "existingSecret": {
          "type": "string"
        },
        "apiKeySecretKey": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "repairPolicy": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "maxUnhealthyNodeThresholdCount": {
          "type": "integer",
          "minimum": 0
        },
        "maxUnhealthyNodeThresholdPercentage": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "maxParallelNodesRepairedCount": {
          "type": "integer",
          "minimum": 0
        },
        "maxParallelNodesRepairedPercentage": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["condition", "minRepairWait", "action"],
            "properties": {
              "condition": {
                "type": "string",
                "minLength": 1
              },
              "reason": {
                "type": "string"
              },
              "minRepairWait": {
                "type": "string",
                "pattern": "^[0-9]+(ns|us|ms|s|m|h)$"
              },
              "action": {
                "type": "string",
                "enum": ["reboot", "replace", "none"]
              }
            }
          }
        }
      }
    }
  }
}
